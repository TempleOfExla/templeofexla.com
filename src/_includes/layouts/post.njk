{% extends "layouts/base.njk" %}

{% block content %}
<article class="blog-post">

  <header class="post-header">
    <h1>{{ title }}</h1>
    <div class="post-meta">
      {% if date %}
        <span class="post-date">{{ date | date("d MMM, yyyy") }}</span>
      {% endif %}
      {% if tags %}
        <div class="post-tags">
          {% for tag in tags %}
            <a href="/tags/{{ tag | slug }}/" class="post-tag-link">#{{ tag }}</a>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </header>

  {% if featured_image %}
    {% image featured_image, title, "post-hero-image" %}
  {% endif %}

  <div class="post-content">
    {{ content | safe }}
  </div>

</article>
{% endblock %}
