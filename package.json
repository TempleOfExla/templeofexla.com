{
  "name": "templeofexla",
  "version": "1.0.0",
  "description": "templeofexla",
  "type": "module",
  "scripts": {
    "start": "npx @11ty/eleventy --serve",
    "start:drafts": "DRAFTS=true npx @11ty/eleventy --serve",
    "build": "npx @11ty/eleventy",
    "cpapps": "mkdir -p src/instruments && cp ../liminal/dist/sympatheia.html src/instruments/sympatheia.html && cp ../texla-bells/dist/bells.html src/instruments/bells.html",
    "crosspost": "node scripts/crosspost.js",
    "new-post": "node scripts/new-post.js"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.0"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "date-fns": "^4.1.0",
    "markdown-it-footnote": "^4.0.0"
  }
}
